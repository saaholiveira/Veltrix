<h1>Editar cadastro de Usuário</h1>

<form action="/Usuario/edit/<%= user.id %>" method="POST">
    <label for="nome">Nome:</label>
    <input type="text" id="nome" name="nome" value="<%= user.nome %>" required>

    <label for="email">Email:</label>
    <input type="email" id="email" name="email" value="<%= user.email %>" required>

    <label for="data_nascimento">Data de Nascimento:</label>
    <input type="date" id="data_nascimento" name="data_nascimento" value="<%= user.data_nascimento.toISOString().split('T')[0] %>" required>

    <button type="submit">Salvar</button>