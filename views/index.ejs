<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Veltrix</title>
    <link rel="stylesheet" href="/public/css/estilo.css">
</head>
<body>
    
    <% include('partials/navbar') %>

    <div class="container">
        <h1>Bem-vindo(a), <%= user.nome %> </h1>
        <p>Ultima atualização: <%= user.ultima_atualizacao %></p><br>
        <div class="container">
            <div class="row">
                <div class="col-md-6 mb-2">
                    <div class="card text-white bg-primary mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Veiculo Atual:</h5>
                            <p class="card-text"><%= meucarroAtual.modelo %></p>
        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-2">
                    <div class="card text-white bg-secondary mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Status do Veiculo:</h5>
                            <p class="card-text"><%= meucarroAtual.status %></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-2">
                <a href="/usuario/" class="btn btn-primary w-100">Usuário</a>
            </div>
            <div class="col-md-3 mb-2">
                <a href="/meucarro/" class="btn btn-primary w-100">Veículos</a>
            </div>
            <div class="col-md-3 mb-2">
                <a href="/monitoramento/" class="btn btn-primary w-100">Monitoramento</a>
            </div>
            <div class="col-md-3 mb-2">
                <a href="/historico/" class="btn btn-primary w-100">Histórico</a>
            </div>
        </div>
    </div>

    <% include('partials/footer') %>
    
</body>

<!--Bootstrap CSS-->
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css">

<!--Seu CSS customizado-->
<link rel="stylesheet" href="/public/css/estilo.css">

<!--Bootstrap JS-->
<script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.3/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/js/bootstrap.min.js
</html>
